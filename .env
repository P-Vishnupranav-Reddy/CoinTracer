# Shared environment for all services
# Database credentials (per request, all set to "postgres")
PGHOST=localhost
PGPORT=5432
PGDATABASE=postgres
PGUSER=postgres
PGPASSWORD=postgres

# Also expose DB_* for services that read these keys
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# Service ports
USER_SERVICE_PORT=3001
EXCHANGE_CONNECTIONS_PORT=5000
MARKET_DATA_SERVICE_PORT=5001
PERSONALIZATION_SERVICE_PORT=3003
FRONTEND_PORT=5173

# Common secrets (dev defaults)
JWT_SECRET=dev-jwt-secret
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
API_KEY_HASH_SECRET=dev-hmac-secret

# Service URLs
MARKET_DATA_SERVICE_URL=http://localhost:5001/api/v1

# CoinMarketCap API (Primary price source)
# Free tier: 10,000 calls/month, 333 calls/day, 30 calls/minute
CMC_API_KEY=0cb4b66710dc4c9abc16a712a90268c4
# Use sandbox for testing (has mock data): https://sandbox-api.coinmarketcap.com
# Use production for real data: https://pro-api.coinmarketcap.com
CMC_BASE_URL=https://pro-api.coinmarketcap.com

# Binance API Configuration
# recvWindow: Max time difference allowed (in ms) between request timestamp and server time
# timeout: Request timeout in milliseconds
BINANCE_RECV_WINDOW=60000
BINANCE_TIMEOUT=60000
BINANCE_REGION=global

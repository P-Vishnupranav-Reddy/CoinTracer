{
  "name": "cointracer-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "frontend",
    "user-service",
    "personalization-service",
    "market-data-service",
    "exchange-connections-service"
  ],
  "scripts": {
    "setup": "npm install",
    "postinstall": "node scripts/setup-git-hooks.js",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "test:all": "node scripts/run-all-tests.js",
    "test:coverage": "npm run test:coverage --workspaces",
    "lint": "node scripts/lint-all-services.js",
    "lint:fix": "node scripts/lint-all-services.js --fix",
    "lint:score": "node scripts/lint-all-services.js --score",
    "dev": "dotenv -e .env -- concurrently -n front,user,personal,market,exchange -c blue,magenta,cyan,yellow,green \"npm:dev:frontend\" \"npm:dev:user-service\" \"npm:dev:personalization-service\" \"npm:dev:market-data-service\" \"npm:dev:exchange-connections-service\"",
    "dev:frontend": "npm run dev -w frontend",
    "dev:user-service": "npm run start -w user-service",
    "dev:personalization-service": "npm run start -w personalization-service",
    "dev:market-data-service": "npm run dev -w market-data-service",
    "dev:exchange-connections-service": "npm run dev -w exchange-connections-service"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "dotenv-cli": "^7.4.2",
    "eslint": "^8.57.1",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.1.1"
  }
}
